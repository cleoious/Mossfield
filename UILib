    local animating     = false
    local savedPos      = UDim2.new(0.5, -winSize.X.Offset / 2, 0.5, -winSize.Y.Offset / 2)
    local grayPalette   = {
        win       = Theme.Gray,
        titleBar  = Color3.fromRGB(45, 44, 58),
    }

    local function hideUI()
        if animating then return end
        animating = true
        visible   = false

        if IsMobile() then
            -- 1) flash gray
            Tween(win,      { BackgroundColor3 = grayPalette.win      }, 0.18)
            Tween(titleBar, { BackgroundColor3 = grayPalette.titleBar }, 0.18)
            task.wait(0.22)
            -- 2) collapse to tiny dot at center
            Tween(win, {
                Size     = UDim2.new(0, 4, 0, 4),
                Position = UDim2.new(0.5, -2, 0.5, -2),
                BackgroundTransparency = 1,
            }, 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In)
            task.wait(0.32)
            win.Visible = false
            -- 3) show circle
            circle.BackgroundTransparency = 1
            circle.Visible = true
            Tween(circle, { BackgroundTransparency = 0 }, 0.25)
        else
            -- 1) flash gray
            Tween(win,      { BackgroundColor3 = grayPalette.win      }, 0.15)
            Tween(titleBar, { BackgroundColor3 = grayPalette.titleBar }, 0.15)
            task.wait(0.18)
            -- 2) shrink to dead center of itself
            local op = win.Position
            local os = win.Size
            Tween(win, {
                Size     = UDim2.new(0, 0, 0, 0),
                Position = UDim2.new(op.X.Scale, op.X.Offset + os.X.Offset / 2,
                                     op.Y.Scale, op.Y.Offset + os.Y.Offset / 2),
                BackgroundTransparency = 1,
            }, 0.28, Enum.EasingStyle.Quart, Enum.EasingDirection.In)
            task.wait(0.3)
            win.Visible = false
        end
        animating = false
    end

    local function showUI()
        if animating then return end
        animating = true
        visible   = true

        -- restore colors first (invisible)
        win.BackgroundColor3   = Theme.BG
        titleBar.BackgroundColor3 = Theme.BG2
        win.BackgroundTransparency = 0
        win.Size     = UDim2.new(0, 0, 0, 0)
        win.Position = UDim2.new(0.5, 0, 0.5, 0)
        win.Visible  = true

        if IsMobile() then
            Tween(circle, { BackgroundTransparency = 1 }, 0.2)
            task.wait(0.22)
            circle.Visible = false
        end

        Tween(win, {
            Size     = winSize,
            Position = savedPos,
        }, 0.36, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
        task.wait(0.38)
        animating = false
    end

    closeBtn.MouseButton1Click:Connect(function()
        savedPos = win.Position   -- remember where it was dragged to
        hideUI()
    end)
    -- ‚ĒÄ‚ĒÄ Circle drag (so it's draggable like the main window) ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    local circleDrag, circleDragStart, circleDragOrigin = false, nil, nil
    local circleMoved = false
    circle.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1
        or i.UserInputType == Enum.UserInputType.Touch then
            circleDrag        = true
            circleMoved       = false
            circleDragStart   = i.Position
            circleDragOrigin  = circle.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if circleDrag and (i.UserInputType == Enum.UserInputType.MouseMovement
                        or i.UserInputType == Enum.UserInputType.Touch) then
            local d = i.Position - circleDragStart
            if math.abs(d.X) > 5 or math.abs(d.Y) > 5 then circleMoved = true end
            circle.Position = UDim2.new(
                circleDragOrigin.X.Scale, circleDragOrigin.X.Offset + d.X,
                circleDragOrigin.Y.Scale, circleDragOrigin.Y.Offset + d.Y
            )
        end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1
        or i.UserInputType == Enum.UserInputType.Touch then
            circleDrag = false
        end
    end)
    circle.MouseButton1Click:Connect(function()
        if not circleMoved then showUI() end
    end)

    -- ‚ĒÄ‚ĒÄ Tab system ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    local tabs      = {}
    local activeTab = nil

    local Window = {}

    function Window:AddTab(tabCfg)
        tabCfg = tabCfg or {}
        local tName = tabCfg.Name or "Tab"

        -- Sidebar button
        local tabBtn = Create("TextButton", {
            Name             = tName .. "_Btn",
            Size             = UDim2.new(1, 0, 0, 32),
            BackgroundColor3 = Theme.BG3,
            BackgroundTransparency = 0.5,
            Text             = "",
            AutoButtonColor  = false,
            Parent           = tabListFrame,
        })
        Corner(tabBtn, Theme.RadiusMd)

        local indicator = Create("Frame", {
            Size             = UDim2.new(0, 3, 0.55, 0),
            Position         = UDim2.new(0, 0, 0.225, 0),
            BackgroundColor3 = Theme.Accent,
            BackgroundTransparency = 1,
            BorderSizePixel  = 0,
            Parent           = tabBtn,
        })
        Corner(indicator, UDim.new(0, 2))

        local tabLabel = Create("TextLabel", {
            Size             = UDim2.new(1, -16, 1, 0),
            Position         = UDim2.new(0, 13, 0, 0),
            BackgroundTransparency = 1,
            Text             = tName,
            TextColor3       = Theme.TextDim,
            Font             = Theme.FontSemi,
            TextSize          = 13,
            TextXAlignment   = Enum.TextXAlignment.Left,
            Parent           = tabBtn,
        })

        -- Content scroll frame
        local tabContent = Create("ScrollingFrame", {
            Name             = tName .. "_Content",
            Size             = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            ScrollBarThickness = 2,
            ScrollBarImageColor3 = Theme.Accent,
            CanvasSize       = UDim2.new(0, 0, 0, 0),
            AutomaticCanvasSize = Enum.AutomaticSize.Y,
            BorderSizePixel  = 0,
            Visible          = false,
            Parent           = contentPanel,
        })
        List(tabContent, 5)
        Pad(tabContent, 9, 9, 10, 10)

        local tabObj = {
            Btn       = tabBtn,
            Content   = tabContent,
            Indicator = indicator,
            Label     = tabLabel,
        }

        local function activate()
            if activeTab then
                Tween(activeTab.Btn,       { BackgroundColor3 = Theme.BG3, BackgroundTransparency = 0.5 }, 0.15)
                Tween(activeTab.Label,     { TextColor3 = Theme.TextDim }, 0.15)
                Tween(activeTab.Indicator, { BackgroundTransparency = 1  }, 0.15)
                activeTab.Content.Visible = false
            end
            activeTab = tabObj
            Tween(tabBtn,    { BackgroundColor3 = Theme.AccentGlow, BackgroundTransparency = 0.72 }, 0.15)
            Tween(tabLabel,  { TextColor3 = Theme.Text }, 0.15)
            Tween(indicator, { BackgroundTransparency = 0 }, 0.15)
            tabContent.Visible = true
        end

        tabBtn.MouseButton1Click:Connect(activate)
        tabBtn.MouseEnter:Connect(function()
            if activeTab ~= tabObj then
                Tween(tabBtn,  { BackgroundTransparency = 0.3 }, 0.1)
                Tween(tabLabel,{ TextColor3 = Theme.TextSub    }, 0.1)
            end
        end)
        tabBtn.MouseLeave:Connect(function()
            if activeTab ~= tabObj then
                Tween(tabBtn,  { BackgroundTransparency = 0.5 }, 0.1)
                Tween(tabLabel,{ TextColor3 = Theme.TextDim    }, 0.1)
            end
        end)

        if #tabs == 0 then task.defer(activate) end
        table.insert(tabs, tabObj)

        -- Attach component API to tabObj (adds to tabContent)
        local compAPI = MakeComponentAPI(tabContent, sg)
        for k, fn in pairs(compAPI) do
            tabObj[k] = fn
        end

        -- ‚ĒÄ‚ĒÄ Sub-tab bar ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
        function tabObj:AddSubTabBar()
            local barFrame = Create("Frame", {
                Name             = "SubTabBar",
                Size             = UDim2.new(1, 0, 0, 30),
                BackgroundColor3 = Theme.BG3,
                BorderSizePixel  = 0,
                Parent           = tabContent,
            })
            Corner(barFrame, Theme.RadiusMd)
            Pad(barFrame, 3, 3, 5, 5)
            List(barFrame, 3, Enum.FillDirection.Horizontal)

            -- container for all sub-tab content frames
            local stContainer = Create("Frame", {
                Name             = "SubTabContainer",
                Size             = UDim2.new(1, 0, 0, 0),
                AutomaticSize    = Enum.AutomaticSize.Y,
                BackgroundTransparency = 1,
                BorderSizePixel  = 0,
                Parent           = tabContent,
            })
            List(stContainer, 5)

            local subTabs    = {}
            local activeSTB  = nil
            local stAPI      = {}

            function stAPI:Add(stName)
                local stBtn = Create("TextButton", {
                    Name             = stName,
                    Size             = UDim2.new(0, 0, 1, 0),
                    AutomaticSize    = Enum.AutomaticSize.X,
                    BackgroundColor3 = Theme.BG2,
                    BackgroundTransparency = 1,
                    Text             = stName,
                    TextColor3       = Theme.TextDim,
                    Font             = Theme.FontSemi,
                    TextSize         = 12,
                    AutoButtonColor  = false,
                    Parent           = barFrame,
                })
                Corner(stBtn, Theme.RadiusSm)
                Pad(stBtn, 0, 0, 10, 10)

                local stContent = Create("Frame", {
                    Name             = stName .. "_Content",
                    Size             = UDim2.new(1, 0, 0, 0),
                    AutomaticSize    = Enum.AutomaticSize.Y,
                    BackgroundTransparency = 1,
                    Visible          = false,
                    BorderSizePixel  = 0,
                    Parent           = stContainer,
                })
                List(stContent, 5)

                local stObj = { Btn = stBtn, Content = stContent }

                local function activateST()
                    if activeSTB then
                        Tween(activeSTB.Btn, { BackgroundTransparency = 1, TextColor3 = Theme.TextDim }, 0.15)
                        activeSTB.Content.Visible = false
                    end
                    activeSTB = stObj
                    Tween(stBtn, { BackgroundTransparency = 0, BackgroundColor3 = Theme.Accent, TextColor3 = Theme.Text }, 0.15)
                    stContent.Visible = true
                end

                stBtn.MouseButton1Click:Connect(activateST)
                if #subTabs == 0 then task.defer(activateST) end
                table.insert(subTabs, stObj)

                -- Return component API scoped to this sub-tab's content
                return MakeComponentAPI(stContent, sg)
            end

            return stAPI
        end

        return tabObj
    end

    -- ‚ĒÄ‚ĒÄ Notifications ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    local notifHolder = Create("Frame", {
        Name             = "Notifications",
        Size             = UDim2.new(0, 285, 1, -20),
        Position         = UDim2.new(1, -295, 0, 10),
        BackgroundTransparency = 1,
        ZIndex           = 200,
        Parent           = sg,
    })
    local notifList = Create("UIListLayout", {
        VerticalAlignment = Enum.VerticalAlignment.Bottom,
        Padding          = UDim.new(0, 7),
        Parent           = notifHolder,
    })

    function Window:Notify(nCfg)
        nCfg = nCfg or {}
        local nTitle  = nCfg.Title       or "Notice"
        local nDesc   = nCfg.Description or ""
        local nType   = nCfg.Type        or "info"
        local nDur    = nCfg.Duration    or 4

        local typeClr = ({
            info    = Theme.Info,
            success = Theme.Success,
            warning = Theme.Warning,
            error   = Theme.Error,
        })[nType] or Theme.Info

        local card = Create("Frame", {
            Name             = "Notif",
            Size             = UDim2.new(1, 0, 0, 62),
            BackgroundColor3 = Theme.BG2,
            BackgroundTransparency = 1,
            ClipsDescendants = true,
            ZIndex           = 200,
            Parent           = notifHolder,
        })
        Corner(card, Theme.RadiusMd)
        Stroke(card, typeClr, 1)

        -- left accent stripe
        local stripe = Create("Frame", {
            Size             = UDim2.new(0, 3, 1, 0),
            BackgroundColor3 = typeClr,
            BorderSizePixel  = 0,
            ZIndex           = 201,
            Parent           = card,
        })
        Corner(stripe, Theme.RadiusSm)

        Create("TextLabel", {
            Size             = UDim2.new(1, -20, 0, 20),
            Position         = UDim2.new(0, 14, 0, 8),
            BackgroundTransparency = 1,
            Text             = nTitle,
            TextColor3       = Theme.Text,
            Font             = Theme.FontBold,
            TextSize         = 13,
            TextXAlignment   = Enum.TextXAlignment.Left,
            ZIndex           = 201,
            Parent           = card,
        })
        Create("TextLabel", {
            Size             = UDim2.new(1, -22, 0, 26),
            Position         = UDim2.new(0, 14, 0, 28),
            BackgroundTransparency = 1,
            Text             = nDesc,
            TextColor3       = Theme.TextSub,
            Font             = Theme.Font,
            TextSize         = 11,
            TextXAlignment   = Enum.TextXAlignment.Left,
            TextWrapped      = true,
            ZIndex           = 201,
            Parent           = card,
        })

        -- progress bar
        local prog = Create("Frame", {
            Size             = UDim2.new(1, -6, 0, 2),
            Position         = UDim2.new(0, 3, 1, -4),
            BackgroundColor3 = typeClr,
            BorderSizePixel  = 0,
            ZIndex           = 202,
            Parent           = card,
        })
        Corner(prog, Theme.RadiusFull)

        -- animate in
        Tween(card, { BackgroundTransparency = 0 }, 0.25)
        -- countdown progress
        Tween(prog, { Size = UDim2.new(0, 0, 0, 2) }, nDur, Enum.EasingStyle.Linear)

        task.delay(nDur, function()
            Tween(card, { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 0) }, 0.28)
            task.delay(0.3, function() card:Destroy() end)
        end)
    end

    -- ‚ĒÄ‚ĒÄ Config save / load ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    local configStore = {}

    function Window:SaveConfig(name, silent)
        name = name or "default"
        local encoded = HttpService:JSONEncode(configStore)
        pcall(writefile, "Mossfield_" .. name .. ".json", encoded)
        -- only notify when explicitly requested (e.g. from UI Settings button)
        if not silent then
            self:Notify({
                Title       = "Config Saved",
                Description = 'Saved as "' .. name .. '"',
                Type        = "success",
                Duration    = 3,
            })
        end
    end

    function Window:LoadConfig(name, silent)
        name = name or "default"
        local ok, raw = pcall(readfile, "Mossfield_" .. name .. ".json")
        if ok and raw then
            local decoded = HttpService:JSONDecode(raw)
            configStore = decoded
            if not silent then
                self:Notify({ Title = "Config Loaded", Description = 'Loaded "' .. name .. '"', Type = "success", Duration = 3 })
            end
            return decoded
        end
        return nil
    end

    function Window:SetConfigValue(key, value) configStore[key] = value end
    function Window:GetConfigValue(key) return configStore[key] end

    -- ‚ĒÄ‚ĒÄ UI Settings tab ‚ÄĒ deferred so it's always the LAST tab ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    task.defer(function()
        local settingsTab = Window:AddTab({ Name = "UI Settings" })

        settingsTab:AddLabel({ Text = "Toggle key (default: RightAlt)" })

        settingsTab:AddKeybind({
            Name     = "Toggle UI",
            Default  = toggleKey,
            Callback = function(key)
                toggleKey = key
            end,
        })

        settingsTab:AddSeparator({ Text = "Config" })

        local configNameBox = settingsTab:AddTextBox({
            Name        = "Config Name",
            Placeholder = "default",
            Default     = "default",
        })

        settingsTab:AddButton({
            Name       = "Save Config",
            ButtonText = "Save",
            Callback   = function()
                local n = configNameBox:GetValue()
                if n == "" then n = "default" end
                Window:SaveConfig(n)   -- not silent ‚Üí shows notification
            end,
        })

        settingsTab:AddButton({
            Name       = "Load Config",
            ButtonText = "Load",
            Callback   = function()
                local n = configNameBox:GetValue()
                if n == "" then n = "default" end
                Window:LoadConfig(n)   -- not silent ‚Üí shows notification
            end,
        })

        settingsTab:AddSeparator()
        settingsTab:AddLabel({ Text = "Mossfield v1.0  ‚ÄĘ  Dark / Purple" })
    end)

    -- ‚ĒÄ‚ĒÄ Toggle key listener ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    UserInputService.InputBegan:Connect(function(inp, gp)
        if gp then return end
        if inp.KeyCode == toggleKey then
            if visible then
                savedPos = win.Position
                hideUI()
            else
                showUI()
            end
        end
    end)

    -- ‚ĒÄ‚ĒÄ Opening animation ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    task.defer(function()
        win.Visible = true
        Tween(win, {
            Size     = winSize,
            Position = savedPos,
        }, 0.42, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    end)

    return Window
end

return Mossfield
