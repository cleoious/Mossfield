    --------------------------------------------------------------------------
    -- COLOR PICKER
    --------------------------------------------------------------------------
    function api:AddColorPicker(cfg)
        cfg = cfg or {}
        local color = cfg.Default or Color3.fromRGB(128, 75, 225)
        local h, s, v = Color3.toHSV(color)
        local isOpen   = false

        local row = Row(38)
        row.ClipsDescendants = false
        row.ZIndex = 4

        RowLabel(row, cfg.Name or "Color")

        local preview = Create("TextButton", {
            Size             = UDim2.new(0, 34, 0, 23),
            Position         = UDim2.new(1, -34, 0.5, -11),
            BackgroundColor3 = color,
            Text             = "",
            AutoButtonColor  = false,
            ZIndex           = 4,
            Parent           = row,
        })
        Corner(preview, Theme.RadiusSm)
        Stroke(preview, Theme.Border, 1)

        -- Picker panel parented to popupLayer to escape ScrollingFrame clipping
        local panelW = 220
        local panel = Create("Frame", {
            Size             = UDim2.new(0, panelW, 0, 0),
            BackgroundColor3 = Theme.BG2,
            ClipsDescendants = true,
            ZIndex           = 200,
            Visible          = false,
            Parent           = popupLayer or row,
        })
        Corner(panel, Theme.RadiusMd)
        Stroke(panel, Theme.Border, 1)

        -- SV area: pure hue background + white-left overlay + black-bottom overlay
        local sv = Create("Frame", {
            Size             = UDim2.new(1, -14, 0, 85),
            Position         = UDim2.new(0, 7, 0, 7),
            BackgroundColor3 = Color3.fromHSV(h, 1, 1),
            BorderSizePixel  = 0,
            ZIndex           = 201,
            Parent           = panel,
        })
        Corner(sv, Theme.RadiusSm)

        -- white ‚Üí transparent (left to right = saturation)
        local svWhite = Create("Frame", {
            Size             = UDim2.new(1, 0, 1, 0),
            BackgroundColor3 = Theme.White,
            BorderSizePixel  = 0,
            ZIndex           = 202,
            Parent           = sv,
        })
        Corner(svWhite, Theme.RadiusSm)
        local wg = Instance.new("UIGradient")
        wg.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(255,255,255)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(255,255,255)),
        })
        wg.Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 0),
            NumberSequenceKeypoint.new(1, 1),
        })
        wg.Rotation = 0
        wg.Parent = svWhite
        svWhite.Active = false

        -- transparent ‚Üí black (top to bottom = value)
        local svBlack = Create("Frame", {
            Size             = UDim2.new(1, 0, 1, 0),
            BackgroundColor3 = Theme.Black,
            BorderSizePixel  = 0,
            ZIndex           = 203,
            Parent           = sv,
        })
        Corner(svBlack, Theme.RadiusSm)
        svBlack.Active = false
        local bg = Instance.new("UIGradient")
        bg.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(0,0,0)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(0,0,0)),
        })
        bg.Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 1),
            NumberSequenceKeypoint.new(1, 0),
        })
        bg.Rotation = 90
        bg.Parent = svBlack

        -- Hue bar using UIGradient
        local hueBar = Create("Frame", {
            Size             = UDim2.new(1, -14, 0, 12),
            Position         = UDim2.new(0, 7, 0, 99),
            BackgroundColor3 = Theme.White,
            BorderSizePixel  = 0,
            ZIndex           = 201,
            Parent           = panel,
        })
        Corner(hueBar, Theme.RadiusFull)
        local hg = Instance.new("UIGradient")
        hg.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0,    Color3.fromHSV(0,   1, 1)),
            ColorSequenceKeypoint.new(0.17, Color3.fromHSV(0.17,1, 1)),
            ColorSequenceKeypoint.new(0.33, Color3.fromHSV(0.33,1, 1)),
            ColorSequenceKeypoint.new(0.5,  Color3.fromHSV(0.5, 1, 1)),
            ColorSequenceKeypoint.new(0.67, Color3.fromHSV(0.67,1, 1)),
            ColorSequenceKeypoint.new(0.83, Color3.fromHSV(0.83,1, 1)),
            ColorSequenceKeypoint.new(1,    Color3.fromHSV(1,   1, 1)),
        })
        hg.Parent = hueBar

        -- Hue knob
        local hueKnob = Create("Frame", {
            Size             = UDim2.new(0, 10, 1, 2),
            Position         = UDim2.new(h, -5, 0, -1),
            BackgroundColor3 = Theme.White,
            ZIndex           = 204,
            Parent           = hueBar,
        })
        Corner(hueKnob, Theme.RadiusFull)
        Stroke(hueKnob, Theme.Black, 1)

        -- SV knob (above all overlays)
        local svKnob = Create("Frame", {
            Size             = UDim2.new(0, 11, 0, 11),
            Position         = UDim2.new(s, -5, 1 - v, -5),
            BackgroundColor3 = Theme.White,
            ZIndex           = 205,
            Parent           = sv,
        })
        Corner(svKnob, Theme.RadiusFull)
        Stroke(svKnob, Theme.Black, 1)

        local function refresh()
            color                    = Color3.fromHSV(h, s, v)
            preview.BackgroundColor3 = color
            sv.BackgroundColor3      = Color3.fromHSV(h, 1, 1)
            hueKnob.Position         = UDim2.new(h, -5, 0, -1)
            svKnob.Position          = UDim2.new(s, -5, 1 - v, -5)
            if cfg.Callback then cfg.Callback(color) end
        end

        -- Hue drag
        local hueDrag = false
        hueBar.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1
            or i.UserInputType == Enum.UserInputType.Touch then
                hueDrag = true
                h = math.clamp((i.Position.X - hueBar.AbsolutePosition.X) / hueBar.AbsoluteSize.X, 0, 1)
                refresh()
            end
        end)
        UserInputService.InputEnded:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1
            or i.UserInputType == Enum.UserInputType.Touch then
                hueDrag = false
            end
        end)
        UserInputService.InputChanged:Connect(function(i)
            if hueDrag and (i.UserInputType == Enum.UserInputType.MouseMovement
                         or i.UserInputType == Enum.UserInputType.Touch) then
                h = math.clamp((i.Position.X - hueBar.AbsolutePosition.X) / hueBar.AbsoluteSize.X, 0, 1)
                refresh()
            end
        end)

        -- SV drag
        local svDrag = false
        sv.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1
            or i.UserInputType == Enum.UserInputType.Touch then
                svDrag = true
                s = math.clamp((i.Position.X - sv.AbsolutePosition.X) / sv.AbsoluteSize.X, 0, 1)
                v = 1 - math.clamp((i.Position.Y - sv.AbsolutePosition.Y) / sv.AbsoluteSize.Y, 0, 1)
                refresh()
            end
        end)
        UserInputService.InputEnded:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1
            or i.UserInputType == Enum.UserInputType.Touch then
                svDrag = false
            end
        end)
        UserInputService.InputChanged:Connect(function(i)
            if svDrag and (i.UserInputType == Enum.UserInputType.MouseMovement
                        or i.UserInputType == Enum.UserInputType.Touch) then
                s = math.clamp((i.Position.X - sv.AbsolutePosition.X) / sv.AbsoluteSize.X, 0, 1)
                v = 1 - math.clamp((i.Position.Y - sv.AbsolutePosition.Y) / sv.AbsoluteSize.Y, 0, 1)
                refresh()
            end
        end)

        preview.MouseButton1Click:Connect(function()
            isOpen = not isOpen
            if isOpen then
                local abs  = preview.AbsolutePosition
                local absS = preview.AbsoluteSize
                -- clamp so panel doesn't go off bottom of screen
                local vp    = workspace.CurrentCamera.ViewportSize
                local panelH = 130
                local posY  = abs.Y + absS.Y + 4
                if posY + panelH > vp.Y - 10 then
                    posY = abs.Y - panelH - 4
                end
                local posX = math.clamp(abs.X + absS.X - panelW, 4, vp.X - panelW - 4)
                panel.Position = UDim2.new(0, posX, 0, posY)
                panel.Size     = UDim2.new(0, panelW, 0, 0)
                panel.Visible  = true
                Tween(panel, { Size = UDim2.new(0, panelW, 0, panelH) }, 0.22)
            else
                Tween(panel, { Size = UDim2.new(0, panelW, 0, 0) }, 0.18)
                task.delay(0.18, function() panel.Visible = false end)
            end
        end)

        -- Close when clicking outside
        UserInputService.InputBegan:Connect(function(inp)
            if not isOpen then return end
            if inp.UserInputType == Enum.UserInputType.MouseButton1
            or inp.UserInputType == Enum.UserInputType.Touch then
                local p  = inp.Position
                local pp = panel.AbsolutePosition
                local ps = panel.AbsoluteSize
                local rp = preview.AbsolutePosition
                local rs = preview.AbsoluteSize
                local inPanel   = p.X >= pp.X and p.X <= pp.X + ps.X and p.Y >= pp.Y and p.Y <= pp.Y + ps.Y
                local inPreview = p.X >= rp.X and p.X <= rp.X + rs.X and p.Y >= rp.Y and p.Y <= rp.Y + rs.Y
                if not inPanel and not inPreview then
                    isOpen = false
                    Tween(panel, { Size = UDim2.new(0, panelW, 0, 0) }, 0.18)
                    task.delay(0.18, function() panel.Visible = false end)
                end
            end
        end)

        return {
            GetValue = function() return color end,
            SetValue = function(_, c)
                color = c
                h, s, v = Color3.toHSV(c)
                refresh()
            end,
        }
    end

    return api
end


