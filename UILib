    --------------------------------------------------------------------------
    -- DROPDOWN
    --------------------------------------------------------------------------
    function api:AddDropdown(cfg)
        cfg = cfg or {}
        local options  = cfg.Options or {}
        local selected = cfg.Default or (options[1] or "Select")
        local isOpen   = false
        local listH    = 0

        local row = Row(38)
        RowLabel(row, cfg.Name or "Dropdown")

        local dropBtn = Create("TextButton", {
            Size             = UDim2.new(0.48, 0, 0, 25),
            Position         = UDim2.new(0.52, 0, 0.5, -12),
            BackgroundColor3 = Theme.BG2,
            Text             = selected,
            TextColor3       = Theme.Text,
            Font             = Theme.Font,
            TextSize         = 12,
            AutoButtonColor  = false,
            ZIndex           = 5,
            Parent           = row,
        })
        Corner(dropBtn, Theme.RadiusSm)
        Stroke(dropBtn, Theme.Border, 1)
        Pad(dropBtn, 0, 0, 8, 20)

        local arrow = Create("TextLabel", {
            Size             = UDim2.new(0, 16, 1, 0),
            Position         = UDim2.new(1, -18, 0, 0),
            BackgroundTransparency = 1,
            Text             = "‚Ėĺ",
            TextColor3       = Theme.Accent,
            Font             = Theme.Font,
            TextSize         = 13,
            ZIndex           = 6,
            Parent           = dropBtn,
        })

        -- list panel parented to popupLayer (top level) to escape ScrollingFrame clipping
        local listFrame = Create("Frame", {
            Size             = UDim2.new(0, 0, 0, 0),
            BackgroundColor3 = Theme.BG2,
            ClipsDescendants = true,
            ZIndex           = 200,
            Visible          = false,
            Parent           = popupLayer or dropBtn,
        })
        Corner(listFrame, Theme.RadiusMd)
        Stroke(listFrame, Theme.Border, 1)

        local scroll = Create("ScrollingFrame", {
            Size                 = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            ScrollBarThickness   = 2,
            ScrollBarImageColor3 = Theme.Accent,
            CanvasSize           = UDim2.new(0, 0, 0, 0),
            AutomaticCanvasSize  = Enum.AutomaticSize.Y,
            ZIndex               = 200,
            Parent               = listFrame,
        })
        List(scroll, 2)
        Pad(scroll, 4, 4, 4, 4)

        local function buildOptions()
            for _, ch in ipairs(scroll:GetChildren()) do
                if ch:IsA("TextButton") then ch:Destroy() end
            end
            for _, opt in ipairs(options) do
                local isSel = opt == selected
                local ob = Create("TextButton", {
                    Size             = UDim2.new(1, 0, 0, 26),
                    BackgroundColor3 = isSel and Theme.AccentGlow or Theme.BG3,
                    Text             = opt,
                    TextColor3       = isSel and Theme.Text or Theme.TextSub,
                    Font             = Theme.Font,
                    TextSize         = 12,
                    AutoButtonColor  = false,
                    ZIndex           = 201,
                    Parent           = scroll,
                })
                Corner(ob, Theme.RadiusSm)
                ob.MouseEnter:Connect(function()
                    if opt ~= selected then Tween(ob, { BackgroundColor3 = Theme.BG4 }, 0.1) end
                end)
                ob.MouseLeave:Connect(function()
                    if opt ~= selected then Tween(ob, { BackgroundColor3 = Theme.BG3 }, 0.1) end
                end)
                ob.MouseButton1Click:Connect(function()
                    selected      = opt
                    dropBtn.Text  = opt
                    if cfg.Callback then cfg.Callback(opt) end
                    isOpen = false
                    Tween(listFrame, { Size = UDim2.new(0, listFrame.AbsoluteSize.X, 0, 0) }, 0.18)
                    Tween(arrow, { Rotation = 0 }, 0.18)
                    task.delay(0.19, function() listFrame.Visible = false end)
                    buildOptions()
                end)
            end
            listH = math.min(#options * 30 + 8, 140)
        end
        buildOptions()

        local function closeList()
            isOpen = false
            Tween(listFrame, { Size = UDim2.new(0, listFrame.AbsoluteSize.X, 0, 0) }, 0.18)
            Tween(arrow, { Rotation = 0 }, 0.18)
            task.delay(0.19, function() listFrame.Visible = false end)
        end

        dropBtn.MouseButton1Click:Connect(function()
            isOpen = not isOpen
            if isOpen then
                -- Position absolutely relative to screen using AbsolutePosition
                local abs  = dropBtn.AbsolutePosition
                local absS = dropBtn.AbsoluteSize
                listFrame.Position = UDim2.new(0, abs.X, 0, abs.Y + absS.Y + 4)
                listFrame.Size     = UDim2.new(0, absS.X, 0, 0)
                listFrame.Visible  = true
                Tween(listFrame, { Size = UDim2.new(0, absS.X, 0, listH) }, 0.2)
                Tween(arrow, { Rotation = 180 }, 0.2)
            else
                closeList()
            end
        end)

        -- Close when clicking outside
        UserInputService.InputBegan:Connect(function(inp)
            if not isOpen then return end
            if inp.UserInputType == Enum.UserInputType.MouseButton1
            or inp.UserInputType == Enum.UserInputType.Touch then
                local p  = inp.Position
                local fp = listFrame.AbsolutePosition
                local fs = listFrame.AbsoluteSize
                local bp = dropBtn.AbsolutePosition
                local bs = dropBtn.AbsoluteSize
                local inList = p.X >= fp.X and p.X <= fp.X + fs.X and p.Y >= fp.Y and p.Y <= fp.Y + fs.Y
                local inBtn  = p.X >= bp.X and p.X <= bp.X + bs.X and p.Y >= bp.Y and p.Y <= bp.Y + bs.Y
                if not inList and not inBtn then closeList() end
            end
        end)

        return {
            SetOptions = function(_, opts) options = opts buildOptions() end,
            SetValue   = function(_, v) selected = v dropBtn.Text = v buildOptions() end,
            GetValue   = function() return selected end,
        }
    end

