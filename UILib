    local notifList = Create("UIListLayout", {
        VerticalAlignment = Enum.VerticalAlignment.Bottom,
        Padding          = UDim.new(0, 7),
        Parent           = notifHolder,
    })

    function Window:Notify(nCfg)
        nCfg = nCfg or {}
        local nTitle  = nCfg.Title       or "Notice"
        local nDesc   = nCfg.Description or ""
        local nType   = nCfg.Type        or "info"
        local nDur    = nCfg.Duration    or 4

        local typeClr = ({
            info    = Theme.Info,
            success = Theme.Success,
            warning = Theme.Warning,
            error   = Theme.Error,
        })[nType] or Theme.Info

        local card = Create("Frame", {
            Name             = "Notif",
            Size             = UDim2.new(1, 0, 0, 62),
            BackgroundColor3 = Theme.BG2,
            BackgroundTransparency = 1,
            ClipsDescendants = true,
            ZIndex           = 200,
            Parent           = notifHolder,
        })
        Corner(card, Theme.RadiusMd)
        Stroke(card, typeClr, 1)

        -- left accent stripe
        local stripe = Create("Frame", {
            Size             = UDim2.new(0, 3, 1, 0),
            BackgroundColor3 = typeClr,
            BorderSizePixel  = 0,
            ZIndex           = 201,
            Parent           = card,
        })
        Corner(stripe, Theme.RadiusSm)

        Create("TextLabel", {
            Size             = UDim2.new(1, -20, 0, 20),
            Position         = UDim2.new(0, 14, 0, 8),
            BackgroundTransparency = 1,
            Text             = nTitle,
            TextColor3       = Theme.Text,
            Font             = Theme.FontBold,
            TextSize         = 13,
            TextXAlignment   = Enum.TextXAlignment.Left,
            ZIndex           = 201,
            Parent           = card,
        })
        Create("TextLabel", {
            Size             = UDim2.new(1, -22, 0, 26),
            Position         = UDim2.new(0, 14, 0, 28),
            BackgroundTransparency = 1,
            Text             = nDesc,
            TextColor3       = Theme.TextSub,
            Font             = Theme.Font,
            TextSize         = 11,
            TextXAlignment   = Enum.TextXAlignment.Left,
            TextWrapped      = true,
            ZIndex           = 201,
            Parent           = card,
        })

        -- progress bar
        local prog = Create("Frame", {
            Size             = UDim2.new(1, -6, 0, 2),
            Position         = UDim2.new(0, 3, 1, -4),
            BackgroundColor3 = typeClr,
            BorderSizePixel  = 0,
            ZIndex           = 202,
            Parent           = card,
        })
        Corner(prog, Theme.RadiusFull)

        -- animate in
        Tween(card, { BackgroundTransparency = 0 }, 0.25)
        -- countdown progress
        Tween(prog, { Size = UDim2.new(0, 0, 0, 2) }, nDur, Enum.EasingStyle.Linear)

        task.delay(nDur, function()
            Tween(card, { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 0) }, 0.28)
            task.delay(0.3, function() card:Destroy() end)
        end)
    end

    -- ‚ĒÄ‚ĒÄ Config save andd load‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    local configStore = {}

    function Window:SaveConfig(name)
        name = name or "default"
        local encoded = HttpService:JSONEncode(configStore)
        local ok = pcall(writefile, "Mossfield_" .. name .. ".json", encoded)
        self:Notify({
            Title       = ok and "Config Saved" or "Save Failed",
            Description = ok and ('Saved as "' .. name .. '"') or "writefile() not available",
            Type        = ok and "success" or "error",
            Duration    = 3,
        })
    end

    function Window:LoadConfig(name)
        name = name or "default"
        local ok, raw = pcall(readfile, "Mossfield_" .. name .. ".json")
        if ok and raw then
            local decoded = HttpService:JSONDecode(raw)
            configStore = decoded
            self:Notify({ Title = "Config Loaded", Description = 'Loaded "' .. name .. '"', Type = "success", Duration = 3 })
            return decoded
        else
            self:Notify({ Title = "Not Found",    Description = 'No config named "' .. name .. '"', Type = "warning", Duration = 3 })
            return nil
        end
    end

    function Window:SetConfigValue(key, value) configStore[key] = value end
    function Window:GetConfigValue(key) return configStore[key] end

    -- ‚ĒÄ‚ĒÄ UI Settings tab ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    local settingsTab = Window:AddTab({ Name = "UI Settings" })

    settingsTab:AddLabel({ Text = "Toggle key (default: RightAlt)" })

    settingsTab:AddKeybind({
        Name    = "Toggle UI",
        Default = toggleKey,
        Callback = function(key)
            toggleKey = key
        end,
    })

    settingsTab:AddSeparator({ Text = "Config" })

    settingsTab:AddTextBox({
        Name        = "Config Name",
        Placeholder = "default",
        Default     = "default",
    })

    settingsTab:AddButton({
        Name       = "Save Config",
        ButtonText = "Save",
        Callback   = function()
            Window:SaveConfig("default")
        end,
    })

    settingsTab:AddButton({
        Name       = "Load Config",
        ButtonText = "Load",
        Callback   = function()
            Window:LoadConfig("default")
        end,
    })

    settingsTab:AddSeparator()
    settingsTab:AddLabel({ Text = "Mossfield v1.0  ‚ÄĘ  Dark / Purple" })

    -- ‚ĒÄ‚ĒÄ Toggle key stuff listener ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    UserInputService.InputBegan:Connect(function(inp, gp)
        if gp then return end
        if inp.KeyCode == toggleKey then
            if visible then
                savedPos = win.Position
                hideUI()
            else
                showUI()
            end
        end
    end)

    -- ‚ĒÄ‚ĒÄ Opening animation ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    task.defer(function()
        win.Visible = true
        Tween(win, {
            Size     = winSize,
            Position = savedPos,
        }, 0.42, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    end)

    return Window
end

return Mossfield

