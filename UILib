    function api:AddColorPicker(cfg)
        cfg = cfg or {}
        local color = cfg.Default or Color3.fromRGB(128, 75, 225)
        local h, s, v = Color3.toHSV(color)
        local isOpen   = false

        local row = Row(38)
        row.ClipsDescendants = false
        row.ZIndex = 4

        RowLabel(row, cfg.Name or "Color")

        local preview = Create("TextButton", {
            Size             = UDim2.new(0, 34, 0, 23),
            Position         = UDim2.new(1, -34, 0.5, -11),
            BackgroundColor3 = color,
            Text             = "",
            AutoButtonColor  = false,
            ZIndex           = 4,
            Parent           = row,
        })
        Corner(preview, Theme.RadiusSm)
        Stroke(preview, Theme.Border, 1)

        -- Picker panel
        local panel = Create("Frame", {
            Size             = UDim2.new(1.3, 0, 0, 0),
            Position         = UDim2.new(-0.15, 0, 1, 6),
            BackgroundColor3 = Theme.BG2,
            ClipsDescendants = true,
            ZIndex           = 30,
            Visible          = false,
            Parent           = row,
        })
        Corner(panel, Theme.RadiusMd)
        Stroke(panel, Theme.Border, 1)

        -- SV gradient
        local sv = Create("ImageLabel", {
            Size             = UDim2.new(1, -14, 0, 90),
            Position         = UDim2.new(0, 7, 0, 8),
            BackgroundColor3 = Color3.fromHSV(h, 1, 1),
            Image            = "rbxassetid://4155801252", -- white->transparent + black overlay
            ScaleType        = Enum.ScaleType.Stretch,
            ZIndex           = 31,
            Parent           = panel,
        })
        Corner(sv, Theme.RadiusSm)

        -- Hue bar
        local hueBar = Create("ImageLabel", {
            Size             = UDim2.new(1, -14, 0, 12),
            Position         = UDim2.new(0, 7, 0, 105),
            Image            = "rbxassetid://4155803839",
            BackgroundColor3 = Theme.White,
            ZIndex           = 31,
            Parent           = panel,
        })
        Corner(hueBar, Theme.RadiusFull)

        -- Hue knob
        local hueKnob = Create("Frame", {
            Size             = UDim2.new(0, 10, 1, 2),
            Position         = UDim2.new(h, -5, 0, -1),
            BackgroundColor3 = Theme.White,
            ZIndex           = 32,
            Parent           = hueBar,
        })
        Corner(hueKnob, Theme.RadiusFull)
        Stroke(hueKnob, Theme.Black, 1)

        -- SV knob
        local svKnob = Create("Frame", {
            Size             = UDim2.new(0, 11, 0, 11),
            Position         = UDim2.new(s, -5, 1 - v, -5),
            BackgroundColor3 = Theme.White,
            ZIndex           = 32,
            Parent           = sv,
        })
        Corner(svKnob, Theme.RadiusFull)
        Stroke(svKnob, Theme.Black, 1)

        local function refresh()
            color              = Color3.fromHSV(h, s, v)
            preview.BackgroundColor3 = color
            sv.BackgroundColor3      = Color3.fromHSV(h, 1, 1)
            hueKnob.Position         = UDim2.new(h, -5, 0, -1)
            svKnob.Position          = UDim2.new(s, -5, 1 - v, -5)
            if cfg.Callback then cfg.Callback(color) end
        end

        -- Hue drag
        local hueDrag = false
        hueBar.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1
            or i.UserInputType == Enum.UserInputType.Touch then
                hueDrag = true
                h = math.clamp((i.Position.X - hueBar.AbsolutePosition.X) / hueBar.AbsoluteSize.X, 0, 1)
                refresh()
            end
        end)
        UserInputService.InputEnded:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1
            or i.UserInputType == Enum.UserInputType.Touch then
                hueDrag = false
            end
        end)
        UserInputService.InputChanged:Connect(function(i)
            if hueDrag and (i.UserInputType == Enum.UserInputType.MouseMovement
                         or i.UserInputType == Enum.UserInputType.Touch) then
                h = math.clamp((i.Position.X - hueBar.AbsolutePosition.X) / hueBar.AbsoluteSize.X, 0, 1)
                refresh()
            end
        end)

        -- SV drag
        local svDrag = false
        sv.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1
            or i.UserInputType == Enum.UserInputType.Touch then
                svDrag = true
                s = math.clamp((i.Position.X - sv.AbsolutePosition.X) / sv.AbsoluteSize.X, 0, 1)
                v = 1 - math.clamp((i.Position.Y - sv.AbsolutePosition.Y) / sv.AbsoluteSize.Y, 0, 1)
                refresh()
            end
        end)
        UserInputService.InputEnded:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1
            or i.UserInputType == Enum.UserInputType.Touch then
                svDrag = false
            end
        end)
        UserInputService.InputChanged:Connect(function(i)
            if svDrag and (i.UserInputType == Enum.UserInputType.MouseMovement
                        or i.UserInputType == Enum.UserInputType.Touch) then
                s = math.clamp((i.Position.X - sv.AbsolutePosition.X) / sv.AbsoluteSize.X, 0, 1)
                v = 1 - math.clamp((i.Position.Y - sv.AbsolutePosition.Y) / sv.AbsoluteSize.Y, 0, 1)
                refresh()
            end
        end)

        preview.MouseButton1Click:Connect(function()
            isOpen = not isOpen
            if isOpen then
                panel.Visible = true
                Tween(panel, { Size = UDim2.new(1.3, 0, 0, 125) }, 0.22)
            else
                Tween(panel, { Size = UDim2.new(1.3, 0, 0, 0) }, 0.18)
                task.delay(0.18, function() panel.Visible = false end)
            end
        end)

        return {
            GetValue = function() return color end,
            SetValue = function(_, c)
                color = c
                h, s, v = Color3.toHSV(c)
                refresh()
            end,
        }
    end

    return api
end


