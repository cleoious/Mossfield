--  COMPONENT FACTORY  (used by both tabs and sub-tabs)
-- ‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź
local function MakeComponentAPI(container, popupLayer)
    local api = {}

    --------------------------------------------------------------------------
    -- internal helpers
    --------------------------------------------------------------------------
    local function Row(h, transparent)
        local f = Create("Frame", {
            Size             = UDim2.new(1, 0, 0, h or 38),
            BackgroundColor3 = transparent and Theme.BG or Theme.BG3,
            BackgroundTransparency = transparent and 1 or 0,
            BorderSizePixel  = 0,
        })
        Corner(f, Theme.RadiusMd)
        Pad(f, 0, 0, 12, 12)
        f.Parent = container
        return f
    end

    local function RowLabel(parent, text)
        return Create("TextLabel", {
            Size              = UDim2.new(0.55, 0, 1, 0),
            BackgroundTransparency = 1,
            Text              = text,
            TextColor3        = Theme.Text,
            Font              = Theme.FontSemi,
            TextSize          = 13,
            TextXAlignment    = Enum.TextXAlignment.Left,
            Parent            = parent,
        })
    end

    --------------------------------------------------------------------------
    -- LABEL
    --------------------------------------------------------------------------
    function api:AddLabel(cfg)
        cfg = cfg or {}
        local f = Row(28, true)
        Create("TextLabel", {
            Size              = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            Text              = cfg.Text or "Label",
            TextColor3        = cfg.Color or Theme.TextSub,
            Font              = Theme.Font,
            TextSize          = 12,
            TextXAlignment    = Enum.TextXAlignment.Left,
            Parent            = f,
        })
    end

    --------------------------------------------------------------------------
    -- SEPARATOR
    --------------------------------------------------------------------------
    function api:AddSeparator(cfg)
        cfg = cfg or {}
        local wrapper = Create("Frame", {
            Size             = UDim2.new(1, 0, 0, 20),
            BackgroundTransparency = 1,
            Parent           = container,
        })
        -- line
        Create("Frame", {
            Size             = UDim2.new(1, 0, 0, 1),
            Position         = UDim2.new(0, 0, 0.5, 0),
            BackgroundColor3 = Theme.Border,
            BorderSizePixel  = 0,
            Parent           = wrapper,
        })
