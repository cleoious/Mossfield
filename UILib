            setStatus("Please enter a key.", Theme.Warning)
            Tween(keyBox, { BackgroundColor3 = Color3.fromRGB(38, 28, 12) }, 0.15)
            task.delay(0.5, function() Tween(keyBox, { BackgroundColor3 = Theme.BG3 }, 0.25) end)
            return
        end
        checking            = true
        enterBtn.Text       = "..."
        enterBtn.TextColor3 = Theme.TextDim
        Tween(enterBtn, { BackgroundColor3 = Theme.BG3 }, 0.15)
        setStatus("Checking key...", Theme.TextDim)

        task.spawn(function()
            local valid = false
            if validator then
                local ok2, res = pcall(validator, key)
                valid = ok2 and res == true
            else
                for _, k in ipairs(validKeys) do
                    if k == key then valid = true break end
                end
            end
            task.wait(0.4)

            if valid then
                setStatus("‚úď  Key accepted!", Theme.Success)
                Tween(enterBtn, { BackgroundColor3 = Theme.Success }, 0.2)
                Tween(keyBox,   { BackgroundColor3 = Color3.fromRGB(12, 32, 20) }, 0.2)
                Tween(boxStroke,{ Color = Theme.Success }, 0.2)
                task.wait(0.85)
                Tween(backdrop, { BackgroundTransparency = 1 }, 0.3)
                Tween(card, {
                    BackgroundTransparency = 1,
                    Size     = UDim2.new(0, cardW * 0.88, 0, cardH * 0.88),
                    Position = UDim2.new(0.5, -cardW * 0.88 / 2, 0.5, -cardH * 0.88 / 2),
                }, 0.32)
                task.wait(0.35)
                ksg:Destroy()
                passed = true
            else
                setStatus("‚úó  Invalid key.", Theme.Error)
                Tween(enterBtn, { BackgroundColor3 = Theme.Error }, 0.15)
                Tween(keyBox,   { BackgroundColor3 = Color3.fromRGB(38, 12, 12) }, 0.15)
                Tween(boxStroke,{ Color = Theme.Error }, 0.15)
                task.wait(0.65)
                enterBtn.Text       = "Enter"
                enterBtn.TextColor3 = Theme.Text
                Tween(enterBtn, { BackgroundColor3 = Theme.Accent }, 0.2)
                Tween(keyBox,   { BackgroundColor3 = Theme.BG3 }, 0.2)
                Tween(boxStroke,{ Color = Theme.Border }, 0.2)
                checking = false
            end
        end)
    end

    enterBtn.MouseButton1Click:Connect(checkKey)
    keyBox.FocusLost:Connect(function(enter) if enter then checkKey() end end)

    -- Open
    card.Visible = true
    showCard()

    -- Yield until passed
    repeat task.wait() until passed
end

