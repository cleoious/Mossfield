    --------------------------------------------------------------------------
    -- SLIDER
    --------------------------------------------------------------------------
    function api:AddSlider(cfg)
        cfg = cfg or {}
        local min    = cfg.Min     or 0
        local max    = cfg.Max     or 100
        local suffix = cfg.Suffix  or ""
        local value  = math.clamp(cfg.Default or min, min, max)

        local row = Row(52)

        -- top row: name + value
        local topRow = Create("Frame", {
            Size             = UDim2.new(1, 0, 0, 20),
            BackgroundTransparency = 1,
            Parent           = row,
        })
        RowLabel(topRow, cfg.Name or "Slider")
        local valLbl = Create("TextLabel", {
            Size             = UDim2.new(0, 55, 1, 0),
            Position         = UDim2.new(1, -55, 0, 0),
            BackgroundTransparency = 1,
            Text             = tostring(value) .. suffix,
            TextColor3       = Theme.AccentBright,
            Font             = Theme.FontBold,
            TextSize         = 12,
            TextXAlignment   = Enum.TextXAlignment.Right,
            Parent           = topRow,
        })

        -- track
        local trackBg = Create("Frame", {
            Size             = UDim2.new(1, 0, 0, 5),
            Position         = UDim2.new(0, 0, 1, -9),
            BackgroundColor3 = Theme.BG,
            BorderSizePixel  = 0,
            Parent           = row,
        })
        Corner(trackBg, Theme.RadiusFull)

        local alpha0 = (value - min) / (max - min)
        local fill = Create("Frame", {
            Size             = UDim2.new(alpha0, 0, 1, 0),
            BackgroundColor3 = Theme.Accent,
            BorderSizePixel  = 0,
            Parent           = trackBg,
        })
        Corner(fill, Theme.RadiusFull)

        local knob = Create("Frame", {
            Size             = UDim2.new(0, 13, 0, 13),
            Position         = UDim2.new(alpha0, -6, 0.5, -6),
            BackgroundColor3 = Theme.White,
            BorderSizePixel  = 0,
            ZIndex           = 2,
            Parent           = trackBg,
        })
        Corner(knob, Theme.RadiusFull)

        -- hit button over track
        local hit = Create("TextButton", {
            Size             = UDim2.new(1, 0, 0, 22),
            Position         = UDim2.new(0, 0, 0.5, -11),
            BackgroundTransparency = 1,
            Text             = "",
            ZIndex           = 3,
            Parent           = trackBg,
        })

        local function applyValue(a)
            a = math.clamp(a, 0, 1)
            value = math.round(min + a * (max - min))
            fill.Size     = UDim2.new(a, 0, 1, 0)
            knob.Position = UDim2.new(a, -6, 0.5, -6)
            valLbl.Text   = tostring(value) .. suffix
            if cfg.Callback then cfg.Callback(value) end
        end

        local sliding = false
        hit.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1
            or inp.UserInputType == Enum.UserInputType.Touch then
                sliding = true
                local a = math.clamp(
                    (inp.Position.X - trackBg.AbsolutePosition.X) / trackBg.AbsoluteSize.X, 0, 1)
                applyValue(a)
            end
        end)
        UserInputService.InputEnded:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1
            or inp.UserInputType == Enum.UserInputType.Touch then
                sliding = false
            end
        end)
        UserInputService.InputChanged:Connect(function(inp)
            if sliding and (inp.UserInputType == Enum.UserInputType.MouseMovement
                         or inp.UserInputType == Enum.UserInputType.Touch) then
                local a = math.clamp(
                    (inp.Position.X - trackBg.AbsolutePosition.X) / trackBg.AbsoluteSize.X, 0, 1)
                applyValue(a)
            end
        end)

        return {
            SetValue = function(_, v)
                local a = (math.clamp(v, min, max) - min) / (max - min)
                applyValue(a)
            end,
            GetValue = function() return value end,
        }
    end

